# ============================================================================
# OpenClaw Marketing Agent System — Environment Variables
# ============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run setup.sh which generates .env automatically with a random gateway token.
# ============================================================================

# --- LLM Providers ---
# Three-tier provider architecture. Set keys for the providers you use.
# If you used 'openclaw onboard' with subscription auth (openai-codex),
# you may not need API keys at all.
#
# Tier 1: OpenAI Codex (subscription via openclaw onboard)
# OPENAI_API_KEY=sk-REPLACE_ME
#
# Tier 2: Google Gemini (API key or auth profile)
# GEMINI_API_KEY=REPLACE_ME
#
# Tier 3: OpenRouter (last-resort fallback)
# OPENROUTER_API_KEY=sk-or-REPLACE_ME
#
# Legacy (no longer default):
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Gateway ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME_WITH_RANDOM_HEX_TOKEN
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789

# --- Paths ---
# Config directory (contains config.json5, extensions/)
OPENCLAW_CONFIG_DIR=~/.openclaw-marketing
# Workspace directory (contains agent workspaces, skills, memory)
OPENCLAW_WORKSPACE_DIR=./workspaces

# --- Diagnostics ---
OPENCLAW_DIAGNOSTICS=1

# --- Channel Tokens (Phase 1) ---
# Slack: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# --- Marketing Platform APIs (Phase 2+) ---
# HUBSPOT_API_KEY=
# GOOGLE_ANALYTICS_KEY=
# META_ADS_TOKEN=

# --- Cost Control: API Key Rotation (Phase 5) ---
# ANTHROPIC_API_KEY_2=sk-ant-...
