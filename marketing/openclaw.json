{
  // ==========================================================================
  // OpenClaw Marketing Agent System — Configuration
  // ==========================================================================

  // --- Gateway Security ---
  gateway: {
    mode: "local",
    bind: "loopback",
    port: 18789,
    trustedProxies: [],
  },

  // --- Auth: multi-account failover ---
  // When one account's quota runs out, auto-switch to the next profile,
  // then fall back to the next provider in the model fallback chain.
  auth: {
    cooldowns: {
      billingBackoffHours: 1,      // retry exhausted account after 1h
      billingMaxHours: 12,         // max backoff cap
    },
  },

  // --- Logging & Diagnostics ---
  logging: {
    level: "info",
    redactSensitive: "tools",
  },
  diagnostics: {
    enabled: true,
    flags: ["gateway.*", "session.*", "webhook.*", "agent.*"],
  },

  // --- Memory ---
  // NOTE: Paths use __WORKSPACE_ROOT__ placeholder, resolved by setup.sh
  memory: {
    backend: "builtin",
    citations: "auto",
    qmd: {
      paths: [
        { path: "__WORKSPACE_ROOT__/marketing/memory/", name: "Marketing Knowledge" },
        { path: "__WORKSPACE_ROOT__/marketing/strategies/", name: "Campaign Strategies" },
        { path: "__WORKSPACE_ROOT__/marketing/performance/", name: "Performance Data" },
        { path: "__WORKSPACE_ROOT__/analytics/memory/", name: "Market Research" },
      ],
      sessions: {
        enabled: true,
        retentionDays: 180,
      },
      update: {
        interval: "5m",
        embedInterval: "30m",
      },
      limits: {
        maxResults: 10,
        maxSnippetChars: 500,
      },
    },
  },

  // --- Agents ---
  agents: {
    defaults: {
      // Primary: OpenAI subscription → Fallbacks: Google (free tier) → OpenRouter (pay-per-use)
      // Three-tier provider architecture: openai-codex, google, openrouter
      model: {
        primary: "openai-codex/gpt-5.3-codex",
        fallbacks: [
          "google/gemini-3-pro-preview",
          "openrouter/auto",
        ],
      },
      // All agents sandboxed by default — tool execution in Docker containers
      sandbox: {
        mode: "all",
        workspaceAccess: "rw",
        docker: {
          network: "none",        // no internet access
          readOnlyRoot: true,     // read-only filesystem
          capDrop: ["ALL"],       // all capabilities removed
        },
      },
    },

    list: [
      // --- Marketing Orchestrator ---
      // NOTE: id MUST be "main" — OpenClaw has a bug where session path
      // validation always checks against agents/main/sessions/ regardless
      // of the actual agent ID. Using any other ID causes:
      //   "Session file path must be within sessions directory"
      {
        id: "main",
        default: true,
        name: "Marketing Orchestrator",
        workspace: "__WORKSPACE_ROOT__/marketing",
        model: {
          primary: "openai-codex/gpt-5.3-codex",
          fallbacks: [
            "google/gemini-3-pro-preview",
            "openrouter/auto",
          ],
        },
        skills: [
          "clawhub",
          "campaign-brief",
          "content-ab-test",
          "campaign-diagnosis",
          "structured-brainstorm",
        ],
        subagents: {
          allowAgents: ["content-writer", "analyst"],
          model: {
            primary: "google/gemini-3-flash-preview",
            fallbacks: [
              "openai-codex/gpt-5.3-codex",
              "openrouter/auto",
            ],
          },
        },
        tools: {
          profile: "full",
          allow: [
            "memory_search",
            "memory_get",
            "sessions_spawn",
            "clawhub",
          ],
        },
        memorySearch: { enabled: true },
        groupChat: {
          mentionPatterns: ["@orchestrator", "@marketing"],
        },
      },

      // --- Content Writer ---
      {
        id: "content-writer",
        name: "Content Writer",
        workspace: "__WORKSPACE_ROOT__/content",
        model: {
          primary: "openai-codex/gpt-5.3-codex",
          fallbacks: [
            "google/gemini-3-pro-preview",
            "openrouter/auto",
          ],
        },
        skills: ["claw1-content-calendar"],
        tools: {
          profile: "full",
          allow: [
            "memory_search",
            "memory_get",
          ],
        },
        memorySearch: { enabled: true },
      },

      // --- Analyst ---
      {
        id: "analyst",
        name: "Marketing Analyst",
        workspace: "__WORKSPACE_ROOT__/analytics",
        model: {
          primary: "google/gemini-3-pro-preview",
          fallbacks: [
            "openrouter/auto",
            "openai-codex/gpt-5.3-codex",
          ],
        },
        skills: ["check-analytics"],
        tools: {
          profile: "full",
          allow: [
            "memory_search",
            "memory_get",
            "browser_screenshot",
            "browser_navigate",
            "browser_snapshot",
          ],
        },
        memorySearch: { enabled: true },
        sandbox: {
          mode: "all",
          workspaceAccess: "ro",
          docker: {
            image: "openclaw-sandbox-browser:bookworm-slim",
          },
          browser: {
            enabled: true,
            headless: true,
          },
        },
      },
    ],
  },

  // --- Channel Bindings ---
  bindings: [
    {
      agentId: "main",
      match: { channel: "telegram", accountId: "*" },
    },
    {
      agentId: "main",
      match: { channel: "slack", accountId: "*" },
    },
  ],

  // --- Session Send Policy ---
  // default: "deny" with explicit allowlist for Telegram + CLI testing
  // schema: src/config/zod-schema.allowdeny.ts:22-33 → { action, match }
  session: {
    sendPolicy: {
      default: "deny",
      rules: [
        { action: "allow", match: { channel: "telegram" } },
        { action: "allow", match: { rawKeyPrefix: "agent:main:main" } },
      ],
    },
  },

  // --- Plugins ---
  // ~/.openclaw/extensions/ is auto-discovered, no need for plugins.load.paths
  // Channel plugins (telegram, discord, etc.) must be explicitly enabled here.
  // Enable via CLI: openclaw plugins enable <name>
  plugins: {
    enabled: true,
    entries: {
      telegram: { enabled: true },
    },
  },

  // --- Cron ---
  // Cron jobs are managed via the API/CLI, not in config.
  // Use: openclaw cron add ... to create jobs after gateway starts.
  cron: {
    enabled: true,
  },
}
